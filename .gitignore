# MaestroStudio - .gitignore

# Build directories
build/
cmake-build-*/
out/
bin/
obj/
*.o
*.a
*.so
*.dylib
*.dll
*.lib
*.exe
*.app/

# IDE files
.idea/
.vs/
*.vcxproj*
*.sln
*.swp
*.swo
*~
*.orig
*.bak

# Qt Creator
.qtcreator/
*.pro.user

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# macOS
.DS_Store
._*
*.dSYM/

# Windows
Thumbs.db
*.ilk
*.pdb
*.idb
*.ipdb

# Linux
*~
.fuse_hidden*

# Test artifacts
*.gcno
*.gcda
coverage/
test_output/

# Documentation build
docs/build/
docs/html/
docs/latex/

# Package files
*.tar.gz
*.zip
*.deb
*.rpm
*.pkg
*.dmg

# Dependencies
libs/
vendor/
vcpkg_installed/
conan/

# Generated files
include/maestro/core/version.hpp.generated
*.moc
*.qrc
ui_*.h

# User settings
*.user
settings.ini
config.local.json

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Audio/MIDI cache
cache/
*.autosave
*.backup

# Mobile build artifacts
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/pubspec.lock
mobile/ios/Pods/
mobile/android/.gradle/
mobile/android/app/build/
